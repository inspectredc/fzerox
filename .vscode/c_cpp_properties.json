{
    "configurations": [
        {
            "name": "Baserom",
            "compilerPath": "${default}",
            "compilerArgs": [
                "-m32"
            ],
            "intelliSenseMode": "${default}", // Shouldn't matter
            "includePath": [
                "${workspaceFolder}/**",
                "src",
                "build",
                "include"
            ],
            "defines": [
                "_LANGUAGE_C",
                "__sgi",
                "_MIPS_SZLONG=32",
                "F3DEX_GBI_2"
            ],
            "cStandard": "gnu89", // C89 + some GNU extensions from C99 like C++ comments
            "cppStandard": "${default}"
        },
        {
            "name": "Expansion Kit",
            "compilerPath": "${default}",
            "compilerArgs": [
                "-m32"
            ],
            "intelliSenseMode": "${default}", // Shouldn't matter
            "includePath": [
                "${workspaceFolder}/**",
                "src",
                "build",
                "include"
            ],
            "defines": [
                "_LANGUAGE_C",
                "__sgi",
                "_MIPS_SZLONG=32",
                "F3DEX_GBI_2",
                "EXPANSION_KIT=1",
                "LEO_VERSION=1",
                "MFS_VERSION=1"
            ],
            "cStandard": "gnu89", // C89 + some GNU extensions from C99 like C++ comments
            "cppStandard": "${default}"
        }
    ],
    "version": 4
}
